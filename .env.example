# Slack Configuration
# Get your tokens from: https://api.slack.com/apps

# User Token (starts with xoxp-)
# Required scopes: users:read, users:read.email, admin.analytics:read, files:read
SLACK_USER_TOKEN=xoxp-YOUR-USER-TOKEN-HERE

# Optional: Bot Token (starts with xoxb-)
# Required scopes: users:read
# Falls back to user token if not set
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN-HERE

# Optional: Output format (text, csv, json)
OUTPUT_FORMAT=text
